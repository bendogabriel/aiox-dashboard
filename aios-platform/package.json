    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "storybook": "^10.2.6",
    "typescript": "~5.9.3",
