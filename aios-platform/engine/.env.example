# ============================================================
# AIOS Engine — Environment Variables
# ============================================================
# Copy to engine/.env for local dev:
#   cp engine/.env.example engine/.env
#
# In Docker, these are passed via docker-compose.yaml environment section.
# ============================================================


# ─── Engine Core ──────────────────────────────── OPTIONAL ──
# ENGINE_PORT=4002                    # Default: 4002
# ENGINE_HOST=0.0.0.0                # Default: 0.0.0.0
# LOG_LEVEL=info                     # debug | info | warn | error


# ─── Secrets Vault ────────────────────────────── REQUIRED ──
# Encryption key for the secrets vault (API keys, OAuth tokens).
# Generate with: openssl rand -hex 32
# IMPORTANT: Change this in production! Default is insecure.
ENGINE_SECRET=aios-dev-secret-change-in-production


# ─── WhatsApp ──────────────────────────────────── OPTIONAL ──
# Provider: "waha" (self-hosted, easy) or "meta" (official API)
# WHATSAPP_PROVIDER=waha

# -- WAHA (self-hosted) --
# 1. docker run -p 3000:3000 devlikeapro/waha
# 2. Scan QR at http://localhost:3000/dashboard
# WAHA_URL=http://localhost:3000
# WAHA_API_KEY=
# WAHA_SESSION=default

# -- Meta Cloud API (requires business verification) --
# Get from: https://developers.facebook.com → WhatsApp → API Setup
# WHATSAPP_PROVIDER=meta
# WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
# WHATSAPP_ACCESS_TOKEN=your-meta-access-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_APP_SECRET=your-app-secret
# WHATSAPP_API_VERSION=v21.0


# ─── Telegram ──────────────────────────────────── OPTIONAL ──
# 1. Create bot via @BotFather on Telegram
# 2. Set token below
# 3. Set webhook URL after engine starts (or use dashboard UI)
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=optional-secret-for-webhook-verification


# ─── Google OAuth ──────────────────────────────── OPTIONAL ──
# For Google Drive and Google Calendar integrations.
# 1. Create project at https://console.cloud.google.com
# 2. Enable Drive API and Calendar API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URI: http://localhost:5173/auth/google/callback
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret


# ─── LLM Providers (fallback) ─────────────────── OPTIONAL ──
# Keys here are used as fallback when not set in the secrets vault.
# Prefer using the dashboard UI (Integrations → API Keys) instead.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=AIza...
